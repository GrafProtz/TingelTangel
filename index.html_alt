<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GridCrime - Die dunkle Seite der Statistik</title>
    
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    
    <link rel="stylesheet" href="style.css" />
    
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
</head>
<body>

    <div id="intro-overlay">
        <div class="branding">
            <h1>GridCrime</h1>
            <p>AUF DER DUNKLEN SEITE DER STATISTIK</p>
        </div>
        <div class="menu-card">
            <select id="city-dropdown-intro">
                <option value="" disabled selected>Einsatzort wählen...</option>
            </select>
            <button class="start-btn" onclick="startGame()">MISSION STARTEN</button>
        </div>
    </div>

    <div id="options-container">
        <h2 style="color: #facc15; margin-top: 0;">In der Kneipe</h2>
        <p id="options-text">Du hörst dich unauffällig um. Was tust du?</p>
        <div id="options-buttons">
            <button class="option-btn" onclick="selectOption('A')">A: Dem Barkeeper Trinkgeld geben (50 €)</button>
            <button class="option-btn" onclick="selectOption('B')">B: Mit den düsteren Gestalten reden</button>
            <button class="option-btn" onclick="selectOption('C')">C: Eine Runde ausgeben (150 €)</button>
            <button class="option-btn" onclick="selectOption('D')">D: Wieder gehen</button>
        </div>
    </div>

    <button id="back-to-menu" onclick="backToMenu()">← Hauptmenü</button>
    <div id="tutorial-container"></div>
    <div id="hud-container" class="hud-bottom">GUTHABEN: 300 €</div>
    <div id="map"></div>
    <div id="pub-overlay-ui" class="pub-inactive" onclick="handlePubOverlayClick()"></div>

    <script>
        // --- GLOBALE VARIABLEN ---
        var map, playerMarker, currentPlayerNodeId;
        var neighborMarkers = [];
        var nodesData = {}, waysData = {}, nodeToWays = {};
        var budget = 300, gameActive = false, moveCounter = 0;
        var pubsData = [], targetPubNode = null, FIXED_PUB_LOCATION = null;
        var targetName = "", tutorialActive = false, tutorialFinished = false, canInteractWithPub = false;
        
        const pubSound = new Audio('https://actions.google.com/sounds/v1/crowds/pub_chatter.ogg');
        pubSound.loop = true;

        const svgContent = `<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' width='40' height='40'><g stroke='#333' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'><path fill='none' d='M16 9h2.5a2.5 2.5 0 0 1 2.5 2.5v3a2.5 2.5 0 0 1-2.5 2.5H16'/><path fill='#FFD700' d='M6 6h10v12a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V6z'/><path fill='none' d='M9 8v9M13 8v9'/><path fill='#FFFFFF' d='M5 6c0-1.5 1.5-2.5 3-2.5 1 0 1.5.5 2.5.5s1.5-.5 2.5-.5c1.5 0 3 1 3 2.5 0 1-1 1.5-1 2.5H6c0-1-1-1.5-1-2.5z'/></g></svg>`;

        // --- INITIALISIERUNG ---
        map = L.map('map', { zoomControl: false }).setView([51.5139, 7.4653], 13);
        L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19,
            attribution: '&copy; OpenStreetMap'
        }).addTo(map);

        // Städte-Liste
        const cities = [
            { name: "Berlin", coords: [52.5200, 13.4050] },
            { name: "Hamburg", coords: [53.5511, 9.9937] },
            { name: "München", coords: [48.1371, 11.5755] },
            { name: "Dortmund", coords: [51.5139, 7.4653] },
            { name: "Köln", coords: [50.9375, 6.9603] }
        ];

        const dropdown = document.getElementById('city-dropdown-intro');
        cities.sort((a,b) => a.name.localeCompare(b.name)).forEach((city, index) => {
            const opt = document.createElement('option');
            opt.value = index;
            opt.textContent = city.name;
            dropdown.appendChild(opt);
        });

        // --- CORE FUNKTIONEN ---

        function startGame() {
            const index = dropdown.value;
            if (index === "") return;
            const city = cities[index];

            // Audio Unlock (Wichtig für Browser-Policies)
            pubSound.play().then(() => { pubSound.pause(); }).catch(e => console.log("Audio Init"));

            document.getElementById('intro-overlay').style.display = 'none';
            document.getElementById('back-to-menu').style.display = 'block';

            map.setView(city.coords, 13);
            showTutorial("INITIALISIERE DATEN-GRID...", city.name.toUpperCase());

            setTimeout(() => {
                map.flyTo(city.coords, 18, { duration: 2 });
                map.once('moveend', () => initGameMap(city.coords));
            }, 1500);
        }

        async function initGameMap(coords) {
            const bounds = map.getBounds();
            const success = await loadNetwork(bounds);
            if (!success) return alert("Fehler beim Laden der OSM-Daten.");

            const intersectionNodes = Object.keys(nodeToWays).filter(id => nodesData[id]);
            
            if (intersectionNodes.length > 0) {
                const startNodeId = intersectionNodes[Math.floor(Math.random() * intersectionNodes.length)];
                
                // Kneipe finden oder Fallback
                if (pubsData.length > 0) {
                    const realPub = pubsData[Math.floor(Math.random() * pubsData.length)];
                    targetPubNode = nodesData[getNearestNodeId(realPub.lat, realPub.lon, intersectionNodes)];
                } else {
                    targetPubNode = nodesData[intersectionNodes[Math.floor(Math.random() * intersectionNodes.length)]];
                }

                FIXED_PUB_LOCATION = L.latLng(targetPubNode.lat, targetPubNode.lon);
                targetName = targetPubNode.tags?.name || "Unbekannte Kneipe";
                
                document.getElementById('pub-overlay-ui').innerHTML = svgContent;
                updatePubOverlay();

                gameActive = true;
                budget = 300;
                updateHUD();
                moveToNode(startNodeId, true);
                
                map.on('move zoom viewreset', updatePubOverlay);
            }
        }

        async function loadNetwork(bounds) {
            const s = bounds.getSouth(), w = bounds.getWest(), n = bounds.getNorth(), e = bounds.getEast();
            const query = `[out:json][timeout:25];(way["highway"](${s},${w},${n},${e});node["amenity"~"pub|bar"](${s},${w},${n},${e}););(._;>;);out body;`;
            
            try {
                const response = await fetch('https://overpass-api.de/api/interpreter', {
                    method: 'POST',
                    body: 'data=' + encodeURIComponent(query)
                });
                const data = await response.json();
                data.elements.forEach(el => {
                    if (el.type === 'node') {
                        nodesData[el.id] = el;
                        if (el.tags?.amenity) pubsData.push(el);
                    } else if (el.type === 'way') {
                        waysData[el.id] = el;
                        el.nodes.forEach(id => {
                            if (!nodeToWays[id]) nodeToWays[id] = new Set();
                            nodeToWays[id].add(el.id);
                        });
                    }
                });
                return true;
            } catch (e) { return false; }
        }

        function moveToNode(nodeId, isInitial = false) {
    if (!gameActive && !isInitial) return;
    
    const node = nodesData[nodeId];
    if (!node) return;

    if (!isInitial) {
        budget -= 10;
        moveCounter++;
        
        // --- DIE VERLORENE TUTORIAL-LOGIK ---
        let hudText = `GUTHABEN: ${budget} €`;
        if (moveCounter >= 3 && targetName) hudText += ` | ${targetName} besuchen`;
        document.getElementById('hud-container').innerText = hudText;

        if (moveCounter === 3) {
            const container = document.getElementById('tutorial-container');
            container.innerHTML += "<br><br><strong style='color:#facc15;'>Besuch die Gaststätte, vielleicht erfährst du dort, wie du schnell an Geld kommen kannst.</strong>";
            container.style.display = 'block';

            // DYNAMISCHE KAMERAFAHRT (Der "Wow"-Effekt)
            if (FIXED_PUB_LOCATION && playerMarker) {
                let bounds = L.latLngBounds([playerMarker.getLatLng(), FIXED_PUB_LOCATION]);
                map.fitBounds(bounds, { padding: [100, 100], animate: true, duration: 1.5 });
            }
        }

        if (moveCounter === 7) {
            document.getElementById('tutorial-container').style.display = 'none';
        }
        
        if (budget <= 0) return gameOver();
    }

    currentPlayerNodeId = nodeId;
    const coords = [node.lat, node.lon];

    if (!playerMarker) {
        createPlayerMarker(coords);
    } else {
        playerMarker.setLatLng(coords);
    }

    // Kamera-Verhalten
    if (isInitial) {
        map.setView(coords, 19);
    } else if (moveCounter !== 3) { // Nicht panen, wenn wir gerade die Übersichtsfahrt bei Schritt 3 machen
        map.panTo(coords);
    }

    updateNeighbors(nodeId);
    evaluateGameState();
}

        function updateNeighbors(nodeId) {
            neighborMarkers.forEach(m => map.removeLayer(m));
            neighborMarkers = [];

            const neighbors = new Set();
            (nodeToWays[nodeId] || []).forEach(wayId => {
                const ns = waysData[wayId].nodes;
                const idx = ns.indexOf(parseInt(nodeId));
                if (idx > 0) neighbors.add(ns[idx-1]);
                if (idx < ns.length - 1) neighbors.add(ns[idx+1]);
            });

            neighbors.forEach(nId => {
                const n = nodesData[nId];
                if (!n) return;
                const m = L.marker([n.lat, n.lon], {
                    icon: L.divIcon({ className: 'neighbor-marker', iconSize: [12, 12] })
                }).addTo(map).on('click', (e) => {
                    L.DomEvent.stopPropagation(e); // Verhindert Karten-Klick
                    moveToNode(nId);
                });
                neighborMarkers.push(m);
            });
        }

        function updatePubOverlay() {
            if (!FIXED_PUB_LOCATION) return;
            const pos = map.latLngToContainerPoint(FIXED_PUB_LOCATION);
            const el = document.getElementById('pub-overlay-ui');
            el.style.display = 'flex';
            el.style.left = pos.x + 'px';
            el.style.top = pos.y + 'px';
        }

        function evaluateGameState() {
            if (!FIXED_PUB_LOCATION || !playerMarker) return;
            const dist = map.distance(playerMarker.getLatLng(), FIXED_PUB_LOCATION);
            const el = document.getElementById('pub-overlay-ui');

            if (dist <= 40) {
                if (!canInteractWithPub) pubSound.play().catch(() => {});
                el.classList.replace('pub-inactive', 'pub-active');
                canInteractWithPub = true;
            } else {
                el.classList.replace('pub-active', 'pub-inactive');
                canInteractWithPub = false;
                pubSound.pause();
            }
        }

        function handlePubOverlayClick() {
            if (canInteractWithPub) {
                gameActive = false;
                document.getElementById('options-container').style.display = 'block';
                neighborMarkers.forEach(m => map.removeLayer(m));
            }
        }

        function selectOption(opt) {
            document.getElementById('options-container').style.display = 'none';
            alert("Du hast " + opt + " gewählt. Die Story geht weiter...");
            gameActive = true;
            updateNeighbors(currentPlayerNodeId);
        }

        function updateHUD() {
            document.getElementById('hud-container').innerText = `GUTHABEN: ${budget} €`;
            document.getElementById('hud-container').style.display = 'block';
        }

        function showTutorial(title, text) {
            const c = document.getElementById('tutorial-container');
            c.innerHTML = `<h2>${title}</h2><p>${text}</p>`;
            c.style.display = 'block';
            if (!tutorialActive) setTimeout(() => { c.style.display = 'none'; }, 5000);
        }

        function getNearestNodeId(lat, lon, ids) {
            let min = Infinity, nearest = null;
            ids.forEach(id => {
                const d = Math.pow(nodesData[id].lat - lat, 2) + Math.pow(nodesData[id].lon - lon, 2);
                if (d < min) { min = d; nearest = id; }
            });
            return nearest;
        }

        function backToMenu() {
            location.reload(); // Einfachste Methode für sauberen Reset
        }

        function gameOver() {
            gameActive = false;
            showTutorial("GAME OVER", "Dein Geld ist alle.");
            document.getElementById('tutorial-container').style.borderColor = "red";
        }

    </script>
</body>
</html>